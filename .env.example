# EdgeOne AI API Gateway 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# =============================================================================
# 管理员配置
# =============================================================================

# 管理员访问令牌（访问 /m 管理后台需要）
# 注意：这是后端验证使用的 Token，不是用户名密码
ADMIN_TOKEN=your-secret-admin-token-here

# 允许访问 API 的前端 Origin，多个值用英文逗号分隔。
# 生产环境必须配置为你的实际域名；未配置时仅允许 http://localhost:5173 便于本地开发。
ALLOWED_ORIGINS=https://your-domain.example

# =============================================================================
# EdgeOne 配置
# =============================================================================

# EdgeOne KV 命名空间 ID（部署到 EdgeOne 时自动配置）
# 本地开发可以忽略
# KV_NAMESPACE_ID=your-kv-namespace-id

# =============================================================================
# 开发环境配置
# =============================================================================

# 调试日志开关（默认关闭）
# 设为 1/true/yes/on 时输出调试日志；生产环境保持关闭。
# 在 EdgeOne 控制台将其配置为环境变量即可生效。
# AIAPI_DEBUG_LOGS=false

# 开发服务器端口（仅本地开发使用）
# VITE_PORT=5173

# =============================================================================
# 可选配置
# =============================================================================

# 上游请求稳定性配置（可选，不配置则使用默认值）
# UPSTREAM_TIMEOUT_MS=60000   # 单次上游请求超时（毫秒），默认 60000
# UPSTREAM_RETRIES=1          # 上游失败重试次数，默认 1

# 说明：熔断器阈值/超时（5 次 / 60 秒 / 半开 1 次）与性能监控窗口（5 分钟）
# 目前在 lib/shared.js 中为固定常量，不通过环境变量配置。

# =============================================================================
# 使用说明
# =============================================================================

# 1. 复制此文件：cp .env.example .env
# 2. 修改 ADMIN_TOKEN 为你的管理员令牌
# 3. 本地开发：npm run dev
# 4. 部署到 EdgeOne：在 EdgeOne 控制台配置环境变量
