{
  "name": "edgeone-aiapi",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "edgeone:dev": "edgeone pages dev --skip-env-sync",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run --coverage",
    "check": "node --check lib/shared.js && node --check edge-functions/api/[[default]].js && node --check edge-functions/v1/chat/completions.js && node --check edge-functions/v1/models.js && vite build"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "markdown-it": "^14.2.0",
    "vite": "^6.0.7",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.6",
    "vitest": "^3.2.6"
  }
}
